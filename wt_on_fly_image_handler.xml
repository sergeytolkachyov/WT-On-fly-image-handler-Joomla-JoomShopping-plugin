<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="jshoppingadmin" method="upgrade">
	<name>PLG_WT_ON_FLY_IMAGE_HANDLER</name>
	<author>Sergey Tolkachyov</author>
	<creationDate>28.03.2026</creationDate>
	<copyright>Copyright (c) 2022 - 2026 Sergey Tolkachyov. All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later</license>
	<authorEmail>info@web-tolk.ru</authorEmail>
	<authorUrl>https://web-tolk.ru</authorUrl>
	<version>2.0.1</version>
	<description>PLG_WT_ON_FLY_IMAGE_HANDLER_DESC</description>
	<namespace path="src">Joomla\Plugin\Jshoppingadmin\Wt_on_fly_image_handler</namespace>
	<scriptfile>script.php</scriptfile>
	<files>
		<folder plugin="wt_on_fly_image_handler">src</folder >
		<folder>services</folder>
		<folder>language</folder>
		<filename>wt_on_fly_image_handler.xml</filename>
	</files>
	<languages folder="language" client="administrator">
		<language tag="ru-RU">ru-RU/plg_jshoppingadmin_wt_on_fly_image_handler.ini</language>
		<language tag="ru-RU">ru-RU/plg_jshoppingadmin_wt_on_fly_image_handler.sys.ini</language>
		<language tag="en-GB">en-GB/plg_jshoppingadmin_wt_on_fly_image_handler.ini</language>
		<language tag="en-GB">en-GB/plg_jshoppingadmin_wt_on_fly_image_handler.sys.ini</language>
	</languages>
	<config>
		<fields name="params">
			<fieldset name="basic">
				<field addfieldprefix="Joomla\Plugin\Jshoppingadmin\Wt_on_fly_image_handler\Fields"
					   type="plugininfo"
					   name="plugininfo"/>
				<field addfieldprefix="Joomla\Plugin\Jshoppingadmin\Wt_on_fly_image_handler\Fields"
					   type="interventionimagestatus"
					   name="interventionimagestatus"/>
				<field type="radio"
					   name="square_image"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_SQUARE_IMAGE"
					   class="btn-group btn-group-yesno"
					   default="0">
					<option value="1">JYES</option>
					<option value="0">JNO</option>
				</field>
				<field type="note"
					   description="PLG_WT_ON_FLY_IMAGE_HANDLER_SQUARE_IMAGE_YES"
					   class="alert alert-info"
					   showon="square_image:1"/>
				<field type="note"
					   description="PLG_WT_ON_FLY_IMAGE_HANDLER_SQUARE_IMAGE_NO"
					   class="alert alert-info"
					   showon="square_image:0"/>
				<field type="radio"
					   name="trim_similar_color"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_TRIM_SIMILAR_COLOR"
					   description="PLG_WT_ON_FLY_IMAGE_HANDLER_TRIM_SIMILAR_COLOR_DESC"
					   class="btn-group btn-group-yesno"
					   filter="int"
					   default="0">
					<option value="1">JYES</option>
					<option value="0">JNO</option>
				</field>
				<field type="number"
					   name="trim_similar_color_tolerance"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_TRIM_SIMILAR_COLOR_TOLERANCE"
					   description="PLG_WT_ON_FLY_IMAGE_HANDLER_TRIM_SIMILAR_COLOR_TOLERANCE_DESC"
					   min="0"
					   max="100"
					   default="20"
					   showon="trim_similar_color:1">
					<option value="1">JYES</option>
					<option value="0">JNO</option>
				</field>
				<field type="color"
					   name="image_fill_color"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_IMAGE_FILL_COLOR"
					   description="PLG_WT_ON_FLY_IMAGE_HANDLER_IMAGE_FILL_COLOR_DESC"
					   default="#ffffff"
					   showon="trim_similar_color:1[OR]square_image:1"/>
				<field type="list"
					   name="output_file_format"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_OUTPUT_FILE_FORMAT"
					   default="jpg">
					<option value="webp">WEBP</option>
					<option value="avif">AVIF</option>
					<option value="jpg">JPG</option>
					<option value="gif">GIF</option>
					<option value="png">PNG</option>
				</field>
				<field type="radio"
					   name="rename_images"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_RENAME_IMAGES"
					   class="btn-group btn-group-yesno"
					   default="0">
					<option value="1">JYES</option>
					<option value="0">JNO</option>
				</field>
				<field type="note"
					   class="alert alert-info"
					   description="PLG_WT_ON_FLY_IMAGE_HANDLER_RENAME_IMAGES_DESC"
					   showon="rename_images:1"/>
			</fieldset>
			<fieldset name="watermark_fieldset" label="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_FIELDSET_LABEL">
				<field type="radio"
					   name="watermark"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_PLACE_WATERMARK"
					   class="btn-group btn-group-yesno"
					   filter="integer"
					   default="0">
					<option value="1">JYES</option>
					<option value="0">JNO</option>
				</field>
				<field name="watermarkfile"
					   type="media"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_FILE_LABEL"
					   description="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_FILE_DESC"
					   folder="images"
					   showon="watermark!:0"
				/>

				<field name="watermarkpercent"
					   type="radio"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_PERCENT_LABEL"
					   description="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_PERCENT_DESC"
					   required="true"
					   class="btn-group btn-group-yesno"
					   default="0"
					   showon="watermark!:0">
					<option value="1">JYES</option>
					<option value="0">JNO</option>
				</field>

				<field name="watermarkpercentvalue"
					   type="text"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_PERCENT_VALUE_LABEL"
					   description="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_PERCENT_VALUE_DESC"
					   default="10"
					   showon="watermarkpercent:1[AND]watermark!:0"
				/>

				<field name="watermarkpos"
					   type="list"
					   required="true"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_POS_LABEL"
					   description="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_POS_DESC"
					   default="topleft"
					   showon="watermark!:0"
				>
					<option value="top-left">Top Left</option>
					<option value="top">Top center</option>
					<option value="top-right">Top right</option>
					<option value="left">Center left</option>
					<option value="center">Center center</option>
					<option value="right">Center right</option>
					<option value="bottom-left">Bottom left</option>
					<option value="bottom">Bottom center</option>
					<option value="bottom-right">Bottom right</option>
				</field>

				<field name="watermarkpadding"
					   type="text"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_PADDING_LABEL"
					   description="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_PADDING_DESC"
					   required="true"
					   default="10"
					   showon="watermark!:0"/>
				<field name="watermark_opacity"
					   type="number"
					   label="PLG_WT_ON_FLY_IMAGE_HANDLER_WATERMARK_OPACITY_LABEL"
					   min="1"
					   max="100"
					   default="100"
					   showon="watermark!:0"/>
			</fieldset>
		</fields>
	</config>
	<updateservers>
        <server type="extension" name="WebTolk - Wt On Fly image handler">https://web-tolk.ru/component/swjprojects/jupdate?element=wt_on_fly_image_handler</server>
    </updateservers>
	<changelogurl>https://web-tolk.ru/jchangelog?element=wt_on_fly_image_handler</changelogurl>
</extension>
